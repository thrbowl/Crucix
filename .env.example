# ============================================
# Crucix Cybersecurity Edition — Configuration
# ============================================
# Copy this file to .env and fill in your keys.
# Keys are optional — sources without keys degrade gracefully.
#
# IMPORTANT: Do NOT put comments on the same line as values.
# Docker env_file treats inline comments as part of the value.

# === Authentication ===

# Enable bearer token auth for /api/* endpoints
AUTH_ENABLED=false
# Access token for API authentication (generate a random string)
AUTH_ACCESS_TOKEN=

# === Domain 1: Vulnerability Intelligence ===

# NVD API (optional, increases rate limit: nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=
# VulnCheck Community (free: vulncheck.com) — v1.1
VULNCHECK_API_KEY=

# === Domain 2: Threat Actors & Malware ===

# Abuse.ch community APIs (MalwareBazaar, ThreatFox, URLhaus API) — free key: https://auth.abuse.ch/
ABUSECH_AUTH_KEY=

# AlienVault OTX (free: otx.alienvault.com)
OTX_API_KEY=
# VirusTotal (free: virustotal.com/gui/join-us)
VIRUSTOTAL_API_KEY=

# === Domain 3: Attack Activity & Exposure ===

# GreyNoise Community (free: viz.greynoise.io/signup)
GREYNOISE_API_KEY=
# Shodan (free: account.shodan.io)
SHODAN_API_KEY=
# AbuseIPDB (free: abuseipdb.com/register)
ABUSEIPDB_API_KEY=
# Cloudflare Radar (free: dash.cloudflare.com/profile/api-tokens)
CLOUDFLARE_API_TOKEN=
# Shadowserver (free: shadowserver.org/what-we-do/network-reporting)
SHADOWSERVER_API_KEY=

# === Domain 4: Event Tracking & Intel Community ===
# (No API keys required for domain 4 sources)

# === Domain 5: China Intelligence Sources ===

# CNVD (cnvd.org.cn)
CNVD_API_KEY=
# CNNVD (cnnvd.org.cn) — 登录官网后从浏览器 Network 中请求头 token 复制；不设则仅能做 HTML/RSS 探测
CNNVD_TOKEN=
# ThreatBook / 微步在线 (x.threatbook.com)
THREATBOOK_API_KEY=
# Qianxin / 奇安信 (ti.qianxin.com)
QIANXIN_API_KEY=
# ZoomEye (zoomeye.org)
ZOOMEYE_API_KEY=
# FOFA (fofa.info)
FOFA_EMAIL=
FOFA_API_KEY=

# === Domain 6: Search Engine Intelligence (v1.1) ===

# X/Twitter API v2 Bearer Token
X_API_BEARER=
# GitHub Personal Access Token
GITHUB_TOKEN=
# Bing News Search API
BING_API_KEY=
# IntelligenceX
INTELX_API_KEY=

# === Commercial Feeds (v1.1, optional) ===

RECORDED_FUTURE_API_KEY=
MANDIANT_API_KEY=
MISP_URL=
MISP_API_KEY=
VT_PRO_API_KEY=

# === Server Configuration ===

PORT=3117
REFRESH_INTERVAL_MINUTES=15

# === Language / 语言 ===
# Default language for the dashboard (en | zh | fr)
CRUCIX_LANG=zh

# === LLM Layer (optional) ===
# Provider options: anthropic | openai | gemini | codex | openrouter | minimax | mistral | ollama | grok
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
OLLAMA_BASE_URL=

# === Watchlist (comma-separated, optional) ===
WATCHLIST_VENDORS=
WATCHLIST_INDUSTRIES=
WATCHLIST_ACTORS=
WATCHLIST_KEYWORDS=
WATCHLIST_CVE_IDS=
WATCHLIST_IP_RANGES=

# === New sources (v1.4.0) ===
TAVILY_API_KEY=           # Tavily AI search — https://tavily.com (already have)
TAVILY_MAX_RESULTS=40     # Max items returned per sweep
TAVILY_ENABLED=true       # Set false to skip Tavily without removing it

HUNTER_API_KEY=           # Qianxin Hunter — https://hunter.how (already have)

QIANXIN_TI_API_KEY=       # Qianxin TI — https://ti.qianxin.com (already have)

BAIDU_QIANFAN_API_KEY=    # Baidu Qianfan — https://qianfan.cloud.baidu.com (already have)
BAIDU_QIANFAN_SECRET_KEY= # Qianfan secret key (needed for auth token)

VULNCHECK_API_KEY=        # VulnCheck — https://vulncheck.com/token (free)
CENSYS_API_ID=            # Censys — https://search.censys.io/account/api (free research)
CENSYS_API_SECRET=
HYBRID_ANALYSIS_KEY=      # Hybrid Analysis — https://www.hybrid-analysis.com/apikeys (free)
MALPEDIA_API_KEY=         # Malpedia — https://malpedia.caad.fkie.fraunhofer.de/api (free)
